		SUB	#100,R2
		BLT	ERROR
		ASL	R2
		CALL	@ATRAP(R2)
		MOV	R0,4(SP)
	TREND:	MOV	(SP)+,R2
		MOV	(SP)+,R0
		RTI
	;
	ERROR::
		CLR	IODEV
		MOV	R2,R5
		ADD	#100,R5
	.BJSR	SETCRT

		CALL	MSTYPE
		TST	LYGIS
		BEQ	MONERR
		BMI	RUNERR
