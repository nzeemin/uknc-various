	RWMOT:	.ASCII	/ON /

	RWTRAP:	.ASCII	/OFF /


	RWON1:	.ASCII	/TRAP /

	RWLINE:	.ASCII	/BF B /
		.EVEN
	;
	IF::	TRAP	100
		.BJSR	CINT
		.T	113		;THEN,GOTO?
		.WORD	RWIF,1002
		TRAP	2
		TRAP	102
		BR	6$
		BR	6$
		MOV	#IFT,(R1)+	;THEN <LINE NUMBER>
		MOV	R0,-(SP)
		CLR	R0
		CALL	TO
		CLR	-(SP)
		BR	5$
	6$:	MOV	#IFF,(R1)+	;THEN	<STATMENT>
		MOV	R0,-(SP)
		MOV	R1,-(SP)
		.T	113
		.WORD	OPRNAM
		.BYTE	2,AOPMON-AOPSUB-2
		CLR	R5
		TST	(R1)+
		CLR	R0
		CALL	@AOPSUB(R5)
		CLR	R2
	5$:
		.T	113

		.WORD	RWIF+12,2	;ELSE?
		BR	62$
		TRAP	102
		BR	50$
		BR	50$
		MOV	#22,R5
		BR	55$
	50$:
		.T	113
		.WORD	OPRNAM
		.BYTE	2,AOPMON-AOPSUB-2
		CLR	R5
	55$:	TST	@SP
		BEQ	4$
		MOV	#JMP,(R1)+
		MOV	R1,R2
		TST	(R1)+
		MOV	R1,@(SP)+
		MOV	R2,-(SP)
	4$:	CALL	@AOPSUB(R5)
	62$:	MOV	(SP)+,R0
		BEQ	7$
		MOV	R1,@R0
	7$:	MOV	(SP)+,R0
		BR	CEND0
	;
	;
	FOR::	CLR	R4
		TRAP	107
		TRAP	13.
		TSTB	R5
		BMI	SYNERR
		TRAP	112
		CMPB	(R3)+,#'=
		BNE	SYNERR
		MOV	R4,-(SP)
		MOV	TYPE,R2
		ASL	R2
		TRAP	100
		.BJSRA	ATCONV(R2)
		MOV	AMOV+4(R2),(R1)+
		MOV	@SP,(R1)+
		.T	113
		.WORD	RWFOR,2
		TRAP	2
		TRAP	100
	10$:	.BJSRA	ATCONV(R2)
		.T	113
		.WORD	RWFOR+3,2
		BR	F2$
		TRAP	100
		.BJSRA	ATCONV(R2)
	F1$:	MOV	AFOR(R2),(R1)+
		MOV	#ASTAR+2,(R1)+
		MOV	(SP)+,(R1)+
		TSTB	LYGIS
		BEQ	CEND

		MOV	R1,-4(R1)
	CEND0:	BR	CEND
	F2$:	TST	R2
		BNE	3$
		MOV	#SCONST,(1)+
		CLR	(R1)+
		MOV	#40200,(R1)+
		BR	F1$
	3$:	MOV	#ICONST,(R1)+
		MOV	#1,(R1)+
		BR	F1$
	SYNERR:	TRAP	2
	;
	AFOR:	.WORD	FORSNG,FORINT
	;
	NEXT::	MOV	#NXSKIP,(R1)+
		CLR	R4
		CLR	R2
		CMPB	@R3,#12
		BEQ	1$
		TRAP	107
		TRAP	13.
		TSTB	R5
		BMI	SYNERR
		MOV	TYPE,R2
		ASL	R2
	1$:	MOV	R4,(1)+
		MOV	ANXADD(R2),(R1)+
		TST	R2
		BNE	2$
		MOV	#NEXCMP,(R1)+
		MOV	#NEXJMP,(R1)+
	2$:	TRAP	112
		CMPB	(R3)+,#',
		BEQ	NEXT
		DEC	R3
		BR	CEND
	;
	ANXADD:	.WORD	NEXSNG,NEXINT
	;
	STOP::	MOV	#HALT,(R1)+
		BR	CEND
	;
	END::	MOV	#ENDPRG,(R1)+
		BR	CEND
	;
	TRON::	MOV	#TRUN,(R1)+
		BR	CEND
	;
	TROFF::	MOV	#TREND,(R1)+
	CEND:	TRAP	106
		RETURN
	;
	DATA::	MOV	R0,@DATPTR
		MOV	R0,DATPTR
		RETURN
	;

	RESTOR::TSTB	LYGIS
		BEQ	3$
		MOV	AUTOON,(1)+
		MOV	R1,AUTOON
		TRAP 	110
		BR	1$
