	.MACRO	.BJMP	ADR
	.IF EQ,MASINA-BK0011
		MOV	#PAG1,-(SP)
		MOV	#ADR,-(SP)
		EMT	56
	.IFF
		JMP	ADR
	.ENDC
	.ENDM
	.MACRO	.BJSR	ADR
	.IF EQ,MASINA-BK0011
		MOV	#PAG1,-(SP)
		MOV	#ADR,-(SP)
		EMT	54
	.IFF
		CALL	ADR
	.ENDC
	.ENDM

	.MACRO	.BJSRA	ADR
	.IF EQ,MASINA-BK0011
		MOV	#PAG1,-(SP)
		MOV	ADR,-(SP)
		EMT	54
	.IFF
		CALL	@ADR
	.ENDC
	.ENDM

	.MACRO	.T	N
	.IF EQ,MASINA-BK0011
		JSR	R0,T'N
	.IFF
		TRAP	N
	.ENDC
	.ENDM


