	MAGNIT::
		MOV	R0,-(SP)
		MOV	R1,-(SP)
		CMP	2(R1),#12
		BNE	2$
		CMP	LENW(R1),#1
		BNE	10$
		CLRB	@R1
		CMP	@R1,#FR.*400
		BNE	8$
	10$:	CMP	NAMEW+6(R1),#401*352
		BEQ	2$

	6$:	ADD	#NAMEW,R1
		MOV	#3,R0
	3$:	MOV	@R1,12(R1)
		MOV	#401*352,(R1)+
		SOB	R0,3$

		MOV	#401*352,(R1)+
		MOV	#401*352,(R1)+
		MOV	@SP,R1
	2$:
		CALL	NOSTOP
		CALL	MOUT
