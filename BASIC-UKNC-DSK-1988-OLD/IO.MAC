		CALL	MOUT
		MOV	#377,R1
		CALL	MOUT
		CALL	MOUT
		CALL	STOPEN
	1$:	TSTB	@#MCSR
		BPL	1$
	8$:	MOV	(SP)+,R1
		MOV	(SP)+,R0
		TSTB	@R1
		BEQ	9$
