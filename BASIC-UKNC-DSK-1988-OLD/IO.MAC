	.MCALL	.HRESET


	.MACRO	.BJSR	N
	.IF EQ,MASINA-BK0011
		MOV	#PAG2,-(SP)
		MOV	#N,-(SP)
		.BJSR0
	.IFF
		CALL	N
	.ENDC
	.ENDM	.BJSR

		; ---------------------------------------
		; ## п≤п²п≤п╕п≤п░п⌡п≤п≈п░п╕п≤п╞ п▒п⌡п·п п░ п▓п▓п·п■п░-п▓п╚п▓п·п■п░ ###
