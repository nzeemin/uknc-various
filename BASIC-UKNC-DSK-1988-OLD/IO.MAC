	.GLOBL	FILTYP,CURS,TABX,TABY,MIDLE,LL,LN,EBUF,LAST,FIRST
	.GLOBL	DFCB,RUSLAT,SCRL,ENDBUF,KOM2P

	MIDM::
		.HRESET
		CALL	NOSTOP
		MOV	#5007,@#BUF
	;	MOV	#BUF,R0
	;1$:	MOV	#5012,(R0)+
	;	CMP	R0,#BEND
	;	BLO	1$
		CLR	@#IODEV
	;
		MOV	#MAXLL,R2
		CALL	SETWDT

	.BJSR	GRINIT

		MOV	#FF,R0
		CALL	ISV
		MOV	#100,R2
		CALL	SETWDT
	;
		CLRB	@#KOM2P
	;
		CALL	STOPEN
		RETURN
	;
	SETWDT::
		MOV	R2,LL
		MOV	#LN+1,R1
		MUL	R2,R1
		ADD	#EBUF,R1
		MOV	R1,ENDBUF
		ASR	R2
		SUB	#MAXLL/2,R2
		NEG	R2
		MOV	R2,MIDLE
		RETURN
	;
		;
		; -------------------
		; ## п╖п╒п∙п²п≤п∙ п║п╒п═п·п п≤ ##
		; -------------------
		;
	ISVTO::	TST	IODEV
		BEQ	ISV
		MOV	#BUFOUT,R1
		MOV	#1,R2

		CMPB	R0,#LF
		BNE	1$
		INC	R2
		MOVB	R0,1(R1)
		MOV	#CR,R0
	1$:
		MOVB	R0,@R1
		JMP	ISVETO

	;---------------------------
	;	FULL SCREEN EDITOR
	;---------------------------

	;-------------------------------------------
	;
	;	п▓п▓п·п■ п║п╒п═п·п п≤
	;		п▓п╚п╔п·п■:	R1-п п·п²п∙п╖п²п╚п≥ п░п■п═п∙п║
	;			#BUF-п²п░п╖п░п⌡п╛п²п╚п≥ п░п■п═п∙п║
	;
	;-------------------------------------------
	IVEIL::
		MOV	R0,-(SP)
		MOV	R3,-(SP)
		MOV	CURS,R1
	1$:	CALL	IV
		CMP	R0,#CR
		BEQ	3$
		CMP	R0,#3
		BEQ	4$
		CMP	R0,#1
		BNE	2$
		CALL	STEP
	2$:	CALL	PROC
		BR	1$
	3$:
		CALL	PROC
		MOV	R1,CURS
		MOV	(SP)+,R3
		MOV	(SP)+,R0
		RETURN
	;
	4$:	MOV	R1,CURS
		JMP	CTRLC
	;
	;--------------------------------
	;	п÷п∙п═п∙п÷п≤п║п п░ п║п╒п═п·п п≤ п▓ п▒пёп╓п∙п═
	;---------------------------------
	;

	INBF0::	MOV	R3,-(SP)	;п■п⌡п╞ INPUT
		MOV	CURS,R1
		MOV	TABX,-(SP)
		SUB	@SP,R1
		CMP	R1,#EBUF
		BEQ	4$
		MOVB	#LF,-1(R1)
	4$:	MOV	R1,-(SP)
		CLRB	SCRL
		CALL	IVEIL
		MOVB	SCRL,R3
		BEQ	2$
	1$:	SUB	LL,@SP
		CMP	@SP,#EBUF
		BEQ	2$
		SOB	R3,1$
	2$:	SUB	LL,R1
		CALL	EPR
		CMP	R3,(SP)+
		BNE	3$
		ADD	@SP,R3
	3$:	CLR	(SP)+
		BR	INBF2
	;
	INBF1::	MOV	R3,-(SP)	;п■п⌡п╞ ANALIZ
		SUB	LL,R1
		CALL	EPR
	;
	INBF2:	MOV	R2,-(SP)
		MOV	R3,R2
		CALL	EPB
		SUB	R2,R3
		BLE	3$
		CMP	R3,#400
		BGE	5$
		INC	R3
		MOV	#BUF,R1
	2$:	MOVB	(R2)+,(R1)+
		SOB	R3,2$
		SEC
		BR	4$
	3$:	CLC
	4$:	MOV	(SP)+,R2
		MOV	(SP)+,R3
		RETURN
	5$:	TRAP	25.
	;
	;----------------------------------------------
	;	п▓п╚п▓п·п■ п║п≤п°п▓п·п⌡п░
	;		п▓п╔п·п■:	п═п·-п п·п■ п║п≤п°п▓п·п⌡п░
	;----------------------------------------------
	;
	ISV::
		MOV	R0,-(SP)
		MOV	R1,-(SP)
		MFPS	-(SP)
		MTPS	#340

		CALL	NOSTOP
		CALL	CSCR

		MOV	CURS,R1
		CALL	PROCLF
		MOV	R1,CURS

		CALL	RSCR
		CALL	STOPEN
		MTPS	(SP)+
		MOV	(SP)+,R1
	ENDISV:
		MOV	(SP)+,R0
		CALL	SETALF
		RETURN
	;
	;--------------------------------------------
	;	п▓п╚п▓п·п■ п║п╒п═п·п п≤
	;		п▓п╔п·п■:	R1-п²п░п╖п░п⌡п╛п²п╚п≥ п░п■п═п∙п║
	;			R2-п■п⌡п≤п²п░ (п°п⌡п░п■п╗п≤п≥ п▒п░п≥п╒)
	;			  -п÷п═п≤п≈п²п░п  п п·п²п╕п░ (п║п╒п░п═п╗п≤п≥ п▒п░п≥п╒)
	;--------------------------------------------
	;
	ISVEIL::
		MOV	R0,-(SP)
		MOV	R3,-(SP)
		MOV	R5,-(SP)
		MFPS	-(SP)
		MTPS	#340
		CALL	NOSTOP

		MOV	R1,R5
		CALL	CSCR
		MOV	CURS,R1
		MOV	R2,R3
		SWAB	R3
	1$:	MOVB	(R5)+,R0
		CMPB	R0,R3
		BEQ	2$
		CALL	PROCLF
		SOB	R2,1$
		BR	3$
	2$:	CALL	PROCLF
	3$:	MOV	R1,CURS

		CALL	RSCR
		CALL	STOPEN
		MTPS	(SP)+
		MOV	(SP)+,R5
		MOV	(SP)+,R3
		BR	ENDISV
	;
	;------------------------------------------
	;	п·п▒п═п░п▒п·п╒п п░ п║п≤п°п▓п·п⌡п░
	;		R0-п║п≤п°п▓п·п⌡
	;		R1-п°п∙п║п╒п· п пёп═п║п·п═п░ п▓ п▒пёп╓п∙п═п∙
	;------------------------------------------

	PROCLF:	CMPB	R0,#LF	;- п÷п═п≤ п▓п╚п▓п·п■п∙ LF=CTRL/U
		BNE	1$
		MOV	#25,R0
	1$:	CMPB	R0,#CR	; CR=CTRL/V
		BNE	PROC
		MOV	#26,R0
	;
	PROC:
		MOV	R2,-(SP)
		MOV	R3,-(SP)

		MOV	#KOD,R2
		TSTB	KOM2P
		BEQ	1$
		ADD	#15,R2
		BIC	#200,R0
		CLRB	KOM2P
		BR	2$
	1$:	CMPB	R0,(R2)+
		BHIS	3$
	2$:	TSTB	@R2
		BEQ	4$
		CMPB	R0,(R2)+
		BNE	2$
	3$:	SUB	#KOD+1,R2
		ASL	R2
		CALL	@KOM(R2)
	4$:
		MOV	(SP)+,R3
		MOV	(SP)+,R2
		RETURN
	;
					;------  п■п⌡п╞ 2-п·п≥ п п·п°.п║п≤п║п╒.
	K33:	INCB	KOM2P
		RETURN
	;
					;------ п▒пёп п▓п░
	K40:	CMP	R0,#177
		BEQ	K177
	;
		MOV	ENDBUF,R2
		DEC	R2
		CMP	R1,R2
		BNE	1$

		TST	CRTGRP
		BEQ	10$
		MOV	R0,-(SP)
		CALL	K10
		MOV	(SP)+,R0
		BR	1$

	10$:	CALL	ROLL
	;
	1$:	CMPB	-1(R1),#LF
		BNE	3$
		MOV	R1,R3

		MOV	TABX,R2
		BEQ	3$
	2$:	CMPB	-(R3),#LF
		BNE	3$
		MOVB	#40,@R3
		SOB	R2,2$
	;
	3$:	MOVB	R0,(R1)+
		INC	TABX
		CALL	ISV0
		CMP	TABX,LL
		BNE	KKK
		JMP	CRLF
	;
	KL:	CLR	RUSLAT
		BR	KK
	;
	KR:	MOV	#-1,RUSLAT
	KK:	CALL	ISV1
	KKK: 	RETURN
					;------ п≈п░п▒п·п≥
	K177:	CALL	EPR
		CMP	R1,R3
		BEQ	2$
		MOVB	#104,R0
		CMPB	-1(R1),#LF
		BEQ	K104
		CALL	K104
	2$:	CALL	K24
	1$:	RETURN
	;
					;------ п⌠п╒
	K11:
		MOVB	#40,R0
	1$:	CALL	K40
		BIT	#7,TABX
		BNE	1$
		RETURN
	;
	;
					;------- п║п╒п═ -п║п▒п═п·п║ п║п╒п═п·п п≤
	K37:
		CALL	EPR
		SUB	TABX,R1
		CLR	TABX
	1$:	CMP	R1,R3
		BEQ	2$
		SUB	LL,R1
		DEC	TABY
		BR	1$
	2$:	CALL	LOK
					;------ п║п╒п║ -п║п▒п═п·п║ п п·п²п╕п░ п║п╒п═п·п п≤
	K13:
		CMPB	@R1,#LF
		BEQ	4$
		CALL	EPB
		MOV	R1,R2

		SUB	TABX,R2
	1$:	MOVB	#113,R0
		CALL	ISV2
		ADD	LL,R2
		CMP	R2,R3
		BHI	2$
		MOV	#LF,R0
		CALL	ISV1
		MOV	#CR,R0
		CALL	ISV1
		BR	1$
	2$:	CALL	LOK
		MOV	R3,R2
		SUB	R1,R2
	3$:	MOVB	#LF,-(R3)
		SOB	R2,3$
	4$: 	RETURN
	;
					;-------- п║п▒п═ -п║п▒п═п·п║ п╜п п═п░п²п░
	K14::
		MOV	#FF,R0
		CALL	ISV1
		CALL	K10
		MOV	ENDBUF,R2
		SUB	R1,R2
		MOV	R1,R3
	1$:	MOVB	#LF,(R3)+
		SOB	R2,1$
		RETURN
	;
	;
					;----- п▓п  -п▓п▓п·п■ п║п╒п═п·п п≤
	K15:
		CALL	EPB
		CALL	KC
		CALL	CRLF
		RETURN
	;
					;------ п пёп═п║п·п═ п▓п▓п∙п═п╔
	K101:	TST 	TABY
		BEQ	1$
		DEC 	TABY
		SUB	LL,R1
		CALL	ISV2
	1$:	RETURN
	;
					;------ п пёп═п║п·п═ п▓п²п≤п≈
	K102:	CMP 	TABY,#LN
		BEQ	1$
		INC  	TABY
		ADD	LL,R1
		CALL	ISV2
	1$:	RETURN
	;
					;------ п пёп═п║п·п═ п²п░п÷п═п░п▓п·
	K103:
		INC	TABX

		CMP	TABX,LL
		BNE	1$
		DEC	TABX
	   	CMP	TABY,#LN
		BEQ	3$
		CLR	TABX
		INC	TABY
		CALL	LOK
		BR	2$
	1$: 	CALL	ISV2
	2$:	INC	R1
	3$:   	RETURN
	;
					;------ п пёп═п║п·п═ п²п░п⌡п∙п▓п·
	K104:	TST	TABX
		BNE	1$
		TST	TABY
		BEQ	4$
		MOV	LL,TABX
		DEC	TABX
		DEC	TABY
		CALL	LOK
		BR	3$
	1$:	DEC	TABX
		CALL	ISV2
	3$:	DEC	R1
	4$: 	RETURN
	;
					;--- R3- п²п░п╖п░п⌡п· п║п╒п═п·п п≤
	EPR:
		MOV	R1,R3
		SUB	TABX,R3
	1$:	CMP	R3,#EBUF
		BEQ	2$
		CMPB	-1(R3),#LF
		BEQ	2$
		SUB	LL,R3
		BR	1$
	2$:	RETURN
	;
					;---- R3- п п·п²п∙п╕ п║п╒п═п·п п≤
	EPB:	MOV	R1,R3
		CMPB	@R3,#LF
		BNE	1$
		TST	TABX
		BEQ	3$
		SUB	TABX,R3
	1$:	CMPB	(R3)+,#LF
		BNE	1$
		DEC	R3
	2$:	CMPB	-1(R3),#40
		BNE	3$
		MOVB	#LF,-(R3)
		BR	2$
	3$:	RETURN
	;
					;----- п═п░п≈п■п▓п≤п√п п░ п║п≤п°п▓п·п⌡п·п▓

	K23:
		CMPB	@R1,#LF
		BEQ	4$
		CALL	EPB
		INC	R3
		CMP	R3,ENDBUF
		BNE	1$

		TST	CRTGRP
		BEQ	10$
		MOV	#7,R0
		JMP	KK

	10$:	CALL	ROLL
		SUB	LL,R3
		BR	2$
	1$:	CMPB	@R3,#LF
		BEQ	2$
		CALL	ROLL2
	2$:	MOV	R3,R2
		SUB	R1,R2
	3$:	MOVB	-(R3),1(R3)
		SOB	R2,3$
		MOVB	#40,@R3
		CALL	EISV
		CALL	LOK
	4$:	RETURN
	;
					;---- п║п■п▓п≤п√п п░ п║п≤п°п▓п·п⌡п·п▓
	K24:	CMPB	@R1,#LF
		BEQ	2$
		MOV	R1,R3
	1$:    	MOVB	1(R3),(R3)+
		CMPB	@R3,#LF
		BNE	1$
		MOV	R1,R3
		CALL	EISV
		MOV	#40,R0
		CALL	ISV1
		CALL	LOK
	2$:	RETURN
	;
					;---- п пёп═п║п·п═ п▓ п п·п²п∙п╕ п║п╒п═п·п п≤
	KC:
		SUB	R1,R3
		BEQ	3$
		ADD	R3,R1
	1$:	SUB	LL,R3
		BMI	2$
		INC	TABY
		BR	1$
	2$:	ADD	LL,R3
		ADD	R3,TABX
		CMP	TABX,LL
		BLT	3$
		INC	TABY
		SUB	LL,TABX

	3$:	RETURN
	;
					;------- п║п■п▓п≤п⌠ п▒пёп╓п∙п═п░ п▓п▓п∙п═п╔
	ROLL:
		MOV	R2,-(SP)
		MOV	R3,-(SP)
		MOV	R1,-(SP)
		MOV	#EBUF,R3
		MOV	ENDBUF,R2
		SUB	LL,R2
		SUB	R3,R2
		MOV	R3,R1
		ADD	LL,R1
	1$:	MOVB	(R1)+,(R3)+
		SOB	R2,1$
		MOV	LL,R2
	2$:	MOVB	#LF,(R3)+
		SOB	R2,2$
		MOV	(SP)+,R1
		MOV	(SP)+,R3
		MOV	(SP)+,R2
		SUB	LL,R1
		DEC	TABY
		INCB	SCRL

		MOV	R0,-(SP)
		MOV	TABY,-(SP)
		MOV	#LN,TABY
		CALL	LOK
		MOV	#LF,R0
		CALL	ISV1
		MOV	(SP)+,TABY
		CALL	LOK
		MOV	(SP)+,R0

		RETURN
	;
					;------- п║п■п▓п≤п⌠ п╖п░п║п╒п≤ п▒пёп╓п∙п═п░ п≤ п╜п п═п░п²п░ п▓п²п≤п≈
	ROLL2:
		MOV	R1,-(SP)
		MOV	TABX,-(SP)
		MOV	TABY,-(SP)
		MOV	R3,-(SP)
		CALL	KC
		CALL	LOK
		MOV	ENDBUF,R3
		MOV	R3,R2
		SUB	R1,R2
		SUB	LL,R2
		BEQ	2$
		MOV	R1,-(SP)
		MOV	R3,R1
		SUB	LL,R1
	1$:	MOVB	-(R1),-(R3)
		SOB	R2,1$
		MOV	(SP)+,R1
	2$:	MOV	LL,R2

	3$:	MOVB	#LF,-(R3)
		SOB	R2,3$
		MOV	ENDBUF,R2
		DEC	R2
		MOVB	#LF,@R2
		INC	R2
		SUB	LL,R2
	4$:	MOV	R1,R3
		MOV	R2,-(SP)
		CALL	EISV
		MOV	#113,R0
		CALL	ISV2
		CALL	KC
		MOV	(SP)+,R2
		CMP	R1,R2
		BGE	5$
		CALL	CRLF
		BR	4$
	5$:
		MOV	(SP)+,R3
		MOV	(SP)+,TABY
		MOV	(SP)+,TABX
		MOV	(SP)+,R1
		CALL	LOK
		RETURN
					;------ п пёп═п║п·п═ п▓ п²п░п╖п░п⌡п· п╜п п═п░п²п░
	K10:
		CLR 	TABX
		CLR 	TABY
		CALL	LOK
		MOV	#EBUF,R1
		RETURN
	;

	K25:				;-------- п пёп═п║п·п═ п▓ п²п░п╖п░п⌡п· п║п⌡п∙п■пёп╝п╘п∙п≥ п║п╒п═п·п п≤
	CRLF:				;	(п╓п≤п≈п≤п╖п∙п║п п·п≥)
		CMP	TABY,#LN
		BNE	1$

		TST	CRTGRP
		BNE	K10

		CALL	ROLL
	1$:	INC	TABY
		ADD	LL,R1

	K26:	SUB	TABX,R1
		CLR	TABX
	;
					;------ п пёп═п║п·п═ п▓ п÷п·п⌡п·п√п∙п²п≤п∙ TABX,TABY
	LOK::
;		MOV	BRKFLG,-(SP)	; //////////
		CALL	NOSTOP
		MOV	#131,R0
		CALL	ISV2
		MOV	TABY,R0
		ADD	#40,R0

		CALL	ISV1
		MOV	TABX,R0
		ADD	MIDLE,R0
		ADD	#40,R0
		CALL	ISV1
;		TSTB	(SP)+	; //////////
;		BEQ	1$	; //////////
		CALL	STOPEN
	1$:	RETURN
	;
	K12::				;------п÷п║ -п÷п∙п═п∙п▓п·п■ п║п╒п═п·п п≤
		CMP	TABY,#LN
		BNE	1$
		CALL	ROLL
	1$:	INC	TABY
		ADD	LL,R1
		BR	ISV1
	;
					;----- п▓п╚п▓п·п■ п÷п░п═п╚  ESC, R0
	ISV2:	TST	R0
		BEQ	2$
