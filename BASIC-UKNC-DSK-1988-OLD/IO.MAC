	;
					;------ п▓п╚п▓п·п■ п║п╒п═п·п п≤ (п░п■п═п∙п║-R3)
	EISV:	MOV	TABX,-(SP)
		MOV	TABY,-(SP)
		MOV	R1,-(SP)
	1$:	CMPB	@R3,#LF
		BEQ	2$
		MOVB	(R3)+,R0
		MOV	R3,-(SP)
		CALL	K40
		MOV	(SP)+,R3
		BR	1$
	2$:	MOV	(SP)+,R1
		MOV	(SP)+,TABY
		MOV	(SP)+,TABX
		CALL	SETALF
		RETURN
	;
	SETALF:	CMPB	RUSLAT+1,RUSLAT		;-----п▓п·п║п║п╒п░п²п·п▓п⌡п∙п²п≤п∙ п═пёп║/п⌡п░п╒
		BEQ	1$
		MOV	#16,-(SP)
		MOVB	RUSLAT+1,RUSLAT
		BNE	3$
		INC	@SP
	3$:	TSTB	@#ARSTV
		BPL	3$
		MOV	(SP)+,@#ARDTV
	1$:	RETURN
	;
					;----- п▓п▓п·п■ п║п≤п°п▓п·п⌡п░ п║ п п⌡п░п▓п≤п░п╒пёп═п╚ п▓ R0
	IV::
		MFPS	-(SP)
		MTPS	#0
	1$:	CMP	FIRST,LAST
		BEQ	1$
		MTPS	(SP)+
	NIM::
		MOVB	@FIRST,R0
		CMPB	R0,#100
		BLO	MOVFRS
		CMPB	R0,#177
		BEQ	MOVFRS
		TSTB	RUSLAT
		BEQ	MOVFRS
		BISB	#200,R0
	MOVFRS:	INC	FIRST
		CMP	FIRST,DFCB
		BNE	1$
		MOV	FCB,FIRST
	1$:	RETURN
	;
	;----- п░п■п═п∙п║п░ п÷п·п■п÷п═п·п⌠п═п░п°п°

	;
	KOM: 	.WORD	K40,KK,K11,K12,K13,K14,K15,KR,KL,K25,K26,KK,K37,K33,K101,K102
		.WORD	K103,K104,K10,K23,K24
		.WORD	K14
	;
	;------ п п·п■п╚ п п⌡п░п▓п≤п╗
	;
	KOD:	.BYTE	40,7,11,LF,13,FF,CR,16,17,25,26,27,37,ESC,101,102,103,104
		.BYTE	110
		.BYTE	23,24
		.BYTE	112
		.BYTE	0
