		.EVEN
		;
		;
		; --------------------------
		; ### п·п╒п·п▒п═п░п√п∙п²п≤п∙ п║п╒п═п·п п≤ ###
		; --------------------------
		; п▓п╔п·п■:	R1- п░п■п═п∙п║ п║п╒п═п·п п≤
		;		R2- п■п⌡п≤п²п░ п║п╒п═п·п п≤ (п°п⌡. п▒п░п≤п╒)
		;		  - п║п≤п°п▓п·п⌡ п·п⌠п═п░п²п≤п╖п≤п╒п∙п⌡п╛ (п║п╒. п▒п░п≤п╒)
		;
	ISVETO::
		TST	IODEV
		BNE	LP
		JMP	ISVEIL
	LP:	MOV	R0,-(SP)
		MOV	R3,-(SP)
		MOV	R2,R3
		SWAB	R3
		CMPB	R3,#LF
		BNE	7$
		MOVB	#CR,R3
	7$:	BIC	#177400,R2
		MOV	@#IODEV,R0
		BPL	FILOUT

	1$:	CMPB	@R1,#'@
		BLO	2$
		CMPB	@R1,#200+'@
		BLO	3$

		TST	@#LPLCFL
		BNE	4$
		MOV	SP,@#LPLCFL
		MOV	#16,R0
		CALL	LPISV
		BR	4$
	3$:
		TST	@#LPLCFL
		BEQ	4$
		CLR	@#LPLCFL
		MOV	#17,R0
		CALL	LPISV
		BR	4$
	2$:

		CMPB	@R1,#LF
		BNE	9$
		MOVB	@R1,R0
		MOVB	#CR,@R1
		INC	R2
		BR	10$

	9$:	CMPB	@R1,#CR
		BEQ	6$
		CMPB	@R1,#FF
		BNE	4$

	6$:	MOV	#-1,@#LPTPOS
	4$:	INC	@#LPTPOS
		MOVB	(R1)+,R0
	10$:	CALL	LPISV

		CMPB	R0,R3
		BEQ	8$
		SOB	R2,1$
		BR	5$

	8$:	DEC	R2
	5$:	MOV	(SP)+,R3
		MOV	(SP)+,R0
		RETURN

	LPISV:
		TSTB	@#IRPR
		BPL	LPISV
		MOV	R0,@#IRPR+2
		RETURN
	;
	FILOUT:
		TST	(SP)+
		MOV	R0,R3
		.BJSR	FNDBUF
		TST	@R0
		BEQ	NOTOP
		BIT	#4000,@R0
		BNE	NOTOUT
		CLR	R3
		BISB	@R0,R3
		ADD	R0,R3
		ADD	#22,R3
		CALL	COPOUT
		MOV	(SP)+,R0
		RETURN

	COPOUT::DEC	R2
		BMI	1$
		MOVB	(R1)+,(R3)+
		INCB	@R0
		BNE	COPOUT
		MOV	R1,-(SP)
		CALL	CASCII
		CALL	CAS

	BIS	#400,@R0
		.BJSR	BLOCKN
		MOV	(SP)+,R1
		SUB	#400,R3
		BR	COPOUT
	1$:	RETURN
	NOTOUT:	TRAP	52.
	NOTOP:	TRAP	59.

	WAIT:
		MFPS	-(SP)
		MTPS	#340
		CLR	@#ARSK
		MTPS	(SP)+
	1$:	TSTB	@#ARSK
		BPL	1$
		MOV	#100,@#ARSK
		RTI

	IVS::	MOVB	@#ARDK,@LAST
		BEQ	WAIT
		INC	LAST
		CMP	LAST,DFCB
		BNE	1$
		MOV	FCB,LAST
	1$:	CMP	LAST,FIRST
		BNE	DEJA
		CALL	MOVFRS
	DEJA:	RTI
