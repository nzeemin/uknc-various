	;
					;------ п▓п╚п▓п·п■ R0
	ISV0::	CMPB	R0,#100
		BLO	ISV1
		CMPB	R0,#300
		BLO	2$
		BICB	#200,R0
		TSTB	RUSLAT
		BNE	ISV1
	1$:	TSTB	@#ARSTV
		BPL	1$
		MOVB	#16,@#ARDTV
		BR	4$
	2$:	TSTB	RUSLAT
		BEQ	ISV1
	3$:	TSTB	@#ARSTV
		BPL	3$
		MOVB	#17,@#ARDTV
	4$:	COMB	RUSLAT
	ISV1::
		TSTB	@#ARSTV
		BPL	ISV1
		MOVB	R0,@#ARDTV

	;!	CMPB	R0,#LF

	;	BNE	6$
