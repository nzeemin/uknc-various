	BRUK::
		MOV	R5,-(SP)
		TST	CRTGRP
		BEQ	10$
		MOV	R0,-(SP)
		MOV	R1,-(SP)
		MOV	#15,R1
	15$:	CLR	R0
		CALL	@#172632
		SOB	R1,15$
		JSR	R4,@#163006
		.WORD	SCR3
		CALL	@160272		;BREAK п÷п·п≥п°п░п² - п║п²п╞п╒п╛ п÷п═п∙п═п╚п▓п░п²п≤п∙
		JSR	R4,@#163006
		.WORD	SCR0
		MOV	(SP)+,R1
		MOV	(SP)+,R0
		BR	11$
	10$:	CALL	@160272		;BREAK п÷п·п≥п°п░п² - п║п²п╞п╒п╛ п÷п═п∙п═п╚п▓п░п²п≤п∙
	11$:	MOV	(SP)+,R5
		TSTB	BRKFLG		;BREAK п═п░п≈п═п∙п╗п∙п²?
		BNE	1$		;п■п░ - п▓п╚п÷п·п⌡п²п╞п╒п╛
		INCB	BRKFLG+1	;п²п∙п╒ - п≈п░п÷п·п°п²п≤п╒п╛
		BR	2$
	1$:	MOV	#BREAKD,R0	;п║п°п∙п²п≤п╒п╛ п п·п÷п≤п╝ п║п╖п∙п╒п╖п≤п п░ п п·п°п░п²п■
		.WORD	33		;п≤п⌡п≤ 32
	2$:	.WORD	12		;п▓п╚п≥п╒п≤ п≤п≈ п÷п═п∙п═п╚п▓п░п²п≤п╞

	;
	;
	BREAKD:				;п▓п╚п÷п·п⌡п²п∙п²п≤п∙ BREAK
		CALL	NOSTOP
		CLR	BRKFLG		;п≈п░п÷п═п∙п╒п≤п╒п╛ BREAK п≤ п·п╖п≤п║п╒п≤п╒п╛ п≈п░п÷п·п°п²п∙п²п²п╚п≥
		MOV	#EBUF,R0
		MOV	TABY,R1
		BEQ	2$
	1$:	ADD	LL,R0
		SOB	R1,1$
	2$:	ADD	TABX,R0
		MOV	R0,CURS
		JMP	BREAK

	NOSTOP::CLRB	BRKFLG
		RETURN

	STOPEN::
		TSTB	BRKFLG+1
		BNE	BREAKD
		INCB	BRKFLG
		RETURN


	SIGNAL::MOV	#7,R0
