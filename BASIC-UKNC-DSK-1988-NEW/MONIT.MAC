	.MACRO	.BJMP	N
	.IF EQ,MASINA-BK0011
		MOV	#PAG2,-(SP)
		MOV	#N,-(SP)
		EMT	56
	.IFF
		JMP	N

	.ENDC
	.ENDM	.BJMP

	.MACRO	.BJSR	N
	.IF EQ,MASINA-BK0011
		MOV	#PAG2,-(SP)
		MOV	#N,-(SP)
		.BJSR0
	.IFF
		CALL	N
	.ENDC
	.ENDM	.BJSR

