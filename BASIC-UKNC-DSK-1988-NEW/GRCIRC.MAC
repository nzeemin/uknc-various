	.SBTTL	POINT	GETTING OF POINT COLOR

	;-----------------------------------------------------------------------------
	; п÷п═п·п╕п∙п■пёп═п░ п÷п·п⌡пёп╖п∙п²п≤п╞ п╕п▓п∙п╒п░ п╒п·п╖п п≤, п≈п░п■п░п²п²п·п≥ п п·п·п═п■п≤п²п░п╒п╚.
	; п║п╒п∙п  п²п░ п▓п╔п·п■п∙:
	; 2(SP)		X-п п·п·п═п■п≤п²п░п╒п░;
	;  (SP)		Y;
	; п║п╒п∙п  п²п░ п▓п╚п╔п·п■п∙:
	;  (SP)		п п·п■ п╕п▓п∙п╒п░ п╒п·п╖п п≤.
	;-----------------------------------------------------------------------------

	POINT::
		TST	CRTGRP
		BEQ	GRPERR		;POINT
		MOV	(SP)+,R2	; Y
		MOV	(SP)+,R1	; X
		MOV	#-1,R0
		CMP	R1,#640.
		BHIS	1$
		CMP	R2,#264.
		BHIS	1$
		CALL	$COLOR
	1$:	MOV	R0,-(SP)	; п▓п·п≈п▓п═п░п╘п░п∙п°п╚п≥ п╕п▓п∙п╒ п╒п·п╖п п≤
		JMP	@(R4)+
	;

