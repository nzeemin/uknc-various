	1$:	RETURN
	;
	KBOFF:	MOV	R1,-(SP)
		CALL	NOSTOP
		MOV	#KBDOFF,R1
		CALL	ESCLN
		MOV	#4000.,R1
	LOOP::	SOB	R1,LOOP
		MTPS	#200
		CLR	@#177560
		MTPS	#0
		MOV	(SP)+,R1
		RETURN
	;
	KBON::	MOV	R1,-(SP)
