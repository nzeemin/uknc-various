	;
	TSTXY:	CMP	R1,#640.	;п п·п²п╒п═п·п⌡п╛ п÷п═п░п▓п≤п⌡п╛п²п·п║п╒п≤
		BLO	2$		;п п·п·п═п■п≤п²п░п╒ X,Y
		BLT	1$
		MOV	#639.,R1
		BR	2$
	1$:	CLR	R1
	2$:	CMP	R2,#264.
		BLO	TSTEND
		BLT	3$
		MOV	#263.,R2
		RETURN
	3$:	CLR	R2
	TSTEND:	RETURN
	;
	TSTC3:	CMP	R3,#8.		;п п·п²п╒п═п·п⌡п╛ п÷п═п░п▓п≤п⌡п╛п²п·п║п╒п≤
		BHI	COLERR		;п╕п▓п∙п╒п·п▓
		CMP	R2,#8.
		BHI	COLERR
	TSTCOL:	CMP	R1,#8.
		BLOS	TSTEND
	;
	GRPERR:
	COLERR:	TRAP	5
	;
	COL3::	MOV	(SP)+,R3	;пёп║п╒п░п²п·п▓п п░ п╕п▓п∙п╒п·п▓:
		MOV	(SP)+,R2	;п╓п·п²п░
		BNE	1$
		MOV	#1,R2		;0 - п╖п∙п═п²п╚п≥
	1$:	TST	R3		;п≈п²п░п п·п°п∙п║п╒п░
		BNE	2$
		MOV	R2,R3		;0 - п╓п·п²п·п▓п╚п≥
	2$:	MOV	(SP)+,R1	;п║п≤п°п▓п·п⌡п·п▓
		BNE	3$
		MOV	R2,R1		;0 - п╓п·п²п·п▓п╚п≥
	3$:	CALL	TSTC3
		MOV	R1,R5
		CALL	COLORS
		JMP	@(4)+
	;
	COLORS::
		TST	CRTGRP
		BNE	GCOLOR
		MOV	#SCR0,R1
		CALL	ESCLN
		JSR	R5,GCOM		;пёп║п╒п░п²п·п▓п п░ п╕п▓п∙п╒п·п▓
		.BYTE	'L,'I
		MOV	R5,CHAR
		DEC	R5
		MOV	R5,R1
		CALL	GINT
		MOV	R3,CHRBOX


		DEC	R3
		MOV	R3,R1
		CALL	GINT
		MOV	R2,PAPER
		DEC	R2
		MOV	R2,R1
		CALL	GINT
	CRET:	MOV	#SCR3,R1
		CALL	ESCLN
		RETURN
	;
	COLG::	MOV	(SP)+,R1	;пёп║п╒п░п²п·п▓п п░ п╕п▓п∙п╒п░ п╖п∙п═п╖п∙п²п≤п╞
		BNE	C1
	CPAP::	MOV	GRPAP,R1	;п╖п∙п═п╒п≤п╒п╛ п╓п·п²п·п▓п╚п°
		BR	C1
	;
	CCHR::	MOV	GRPEN,R1	;п╖п∙п═п╒п≤п╒п╛ п╒п∙п п╚п╘п≤п° п╕п▓п∙п╒п·п°
	C1:	CALL	COLSET
		JMP	@(4)+
	;
	GCOLOR:	MOV	R2,GRPAP
