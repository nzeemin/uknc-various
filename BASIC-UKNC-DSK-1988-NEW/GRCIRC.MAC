	1$:	ADD	R2,@SP
		BR	LSTPE
	;
	LSTP::	ADD	6(SP),2(SP)
		BVC	1$
		MOV	#639.,2(SP)
	1$:	ADD	4(SP),@SP
	LSTPE:	BVC	2$
		MOV	#263.,@SP
	2$:	JMP	@(R4)+

		BVS	GRPERR
		JMP	@(R4)+
	;


	SPFORM::
		TST	@SP
		BNE	1$
		MOV	@#GRPAP,@SP
	1$:
		JMP	@(R4)+
