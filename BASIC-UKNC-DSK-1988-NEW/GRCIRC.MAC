		BR	GC
	;
	COLSET:	TST	CRTGRP
		BEQ	GRPERR
		CALL	TSTCOL
	GC:	DEC	R1
		JSR	R5,GCOM
		.BYTE	'M,'L
		CALL	GINT
	;!	MOV	#100,@#ARSK
		RETURN
	;
	CURCOR::CALL	GXYR
		MOV	R1,-(SP)
		MOV	R2,-(SP)
		JMP	@(R4)+
	;
	STP::	CALL	GXYR
		ADD	R1,2(SP)
		BVC	1$
