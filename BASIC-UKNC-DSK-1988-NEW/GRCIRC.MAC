	;
	GCOM::;!	CALL	NOSTOP
		MOV	#33,R0		;п⌠п═п░п╓п≤п╖п∙п║п п░п╞ п п·п°п░п²п■п░
		CALL	GOUT		;п·п▒п═п░п╘п∙п²п≤п∙: JSR R5,GCOM
		MOVB	(R5)+,R0	;	    .BYTE 'U,'G
		CALL	GOUT
