	$KEY::
		MOV	(SP)+,R5
		CMP	R5,#16.
		BLOS	1$
		MOV	#16.,R5
	1$:	MOV	(SP)+,R2
		MOV	(SP)+,R3
		BLE	GERROR
		CMP	R3,#20.
		BGT	GERROR
		MOV	#KESC,R1
		CALL	ESCLN
		MOV	#'0,R0
	22$:	CMP	R3,#10.
		BLT	2$
		SUB	#10.,R3
		INC	R0


		BR	22$
	2$:	CMP	R0,#'0
		BEQ	20$
		CALL	GOUT
	20$:	MOV	R3,R0
		ADD	#'0,R0
		CALL	GOUT
		MOV	#'/,R0
		CALL	GOUT
	3$:	DEC	R5
		BLT	8$
		MOVB	@R2,R0
		ASR	R0
		ASR	R0
		ASR	R0
		ASR	R0
		CMP	R0,#10.
		BGE	4$
		ADD	#'0,R0
		BR	5$
	4$:	ADD	#67,R0
	5$:	CALL	GOUT
		MOVB	(2)+,R0
		BIC	#177760,R0
		CMP	R0,#10.
		BGE	6$
		ADD	#'0,R0
		BR	7$
	6$:	ADD	#'7,R0
	7$:	CALL	GOUT
		BR	3$
	8$:	MOV	#KENDSC,R1
		CALL	ESCLN
		MOV	CRTGRP,R1
		MOV	RETSCR(1),R1
		CALL	ESCLN
		JMP	@(4)+
