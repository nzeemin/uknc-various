	;************************************************
	;		п÷п═п·п⌠п═п░п°п░  п·п÷п∙п═п░п╒п·п═п░ DRAW
	;	п²п░ п▓п╔п·п■п∙:	п▓ п║п╒п∙п п∙ 2(SP) -п░п■п═п∙п║ п║п╒п═п·п п≤
	;				 (SP) -п■п⌡п≤п²п░ п║п╒п═п·п п≤
	;	п²п░ п▓п╚п╔п·п■п∙:	п║п╒п∙п  п÷пёп║п╒
	;	п▓п║п∙ п═п∙п⌠п≤п║п╒п═п╚ п║п·п╔п═п░п²п╝п╒п║п╞.
	;	п÷п═п≤ п▓п╚п≈п·п▓п░п╔ $CONST,$VALUE,$STRNG R4 п║п·п╔п═.
	;************************************************
	;
	$DRAW::
		MOV	R4,SAVJMP
		CALL	CLRTSP
		POP	<R5,R3>		; п≤п≈п▓п⌡п∙п╖п╛ п■п⌡. п≤ п░п■п═.п║п╒п═
		BEQ	OUT
		CALL	GXYR		; п²п░п╖п░п⌡п╛п²п·п∙ п÷п·п⌡п·п√п∙п²п≤п∙
		MOV	R5,R0		; п║п·п╔п═п░п²п≤п╒п╛
		PUSH	<R0,CHAR>	; п║п·п╔п═. R5,п╕п▓п∙п╒
		CLR	-(SP)		; п≈п░п÷п≤п║п╛ п║п⌡п·п▓( 0,0 -п÷п═п≤п≈п²п░п  п·п п·п²п╖п░п²п≤п╞ ),
		CLR	-(SP)
		MOV	#70000,-(SP)	; п≤ п║п⌡п·п▓п░ п÷п∙п═п∙п°п∙п╘п∙п²п≤п≥  ( WM )( 70000 )
	NEWSTR:
		TST	R3		; п²пёп⌡п∙п▓п·п≥ п░п■п═п∙п║-п÷п═п≤п≈п²п░п  п п·п²п╕п░ ?
		BEQ	OUT		; п■п░--п▓п╚п╔п·п■ п≤п≈  $DRAW
		ADD	R3,R5		; п п·п═п═п∙п п╕п≤п╞ R5<--п░п■п═п∙п║ п÷п·п║п⌡п∙п■п². п▒п░п≥п╒п░ п║п╒п═п·п п≤
		DEC	R5
	AGAIN:
	;----------------------------------------------------------------------
	;  SKANER п·п÷п═п∙п■п∙п⌡п╞п∙п╒ п÷п═п≤п²п░п■п⌡п∙п√п²п·п║п╒п╛ п║п≤п°п▓п·п⌡п░ (R3) п  п п⌡п╝п╖п░п°.п■п⌡п╞ п п⌡п╝п╖п∙п▓п·п⌠п·
	;	  B R0 п║п°п∙п╘п∙п²п≤п∙ п∙п⌠п· п▓  п║п╒п═п·п п∙ KEY пёп°п²п·п√п∙п²п²п·п∙ п²п░ 2
	;	!!!!! R3 п²п░ п▓п╚п╔п·п■п∙ пёп п░п≈п╚п▓п░п∙п╒ п²п░ п║п⌡п∙п■пёп╝п╘п≤п≥  п║п≤п°п▓Oп⌡  !!!!!!
	;----------------------------------------------------------------------
	;SKANER
		TRAP	112
		CMP	R3,R5		; п п·п²п∙п╕ п·п▒п═п░п▒п·п╒п п≤ п÷п·п■п║п╒п═п·п п≤?
		BHI	NEXT		; п■п░
		CLR	R0		; п÷п∙п═п▓п·п²п░п╖п░п⌡п╛п²п·  п²пёп⌡п∙п▓п·п∙ п║п°п∙п╘п∙п²п≤п∙
	1$:	CMPB	KEY(R0),(R3)	; п║п≤п°п▓п·п⌡п╚ п║п╔п·п■п╞п╒п║п╞
		BEQ	2$		; п■п░-п²п░ п▓п╚п╔п·п■
		INC	R0		; п²п∙п╒--п║п⌡п∙п■пёп╝п╘п≤п≥
		TSTB	KEY(R0)		; п²пёп⌡п∙п▓п·п≥ ? п■п░-п²п░ п▓п╚п╔п·п■
		BNE	1$		; п²п∙п╒--п·п÷п╞п╒п╛ п║п═п░п▓п²п∙п²п≤п∙
		BR	ERROR		; п²п∙ п п⌡п╝п╖
