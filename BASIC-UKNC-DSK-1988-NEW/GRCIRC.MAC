	ESCLN::	MOV	R0,-(SP)
	2$:	MOVB	(1)+,R0
		BEQ	1$
		CALL	GOUT
		BR	2$
	1$:	MOV	(SP)+,R0
		RETURN
	;
	SETCRT::TST	CRTGRP
		BEQ	1$
		MOV	#SET3,R1
		CALL	ESCLN
		CLR	CRTGRP
		MOV	#14,R0
