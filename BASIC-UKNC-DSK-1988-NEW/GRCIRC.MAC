		RTS	R5
	;
	MIG::
		MOV	R1,-(SP)
		MOV	#SCR0,R1
		CALL	ESCLN
		MOV	(SP)+,R1
		JSR	R5,GCOM		;пёп║п╒п░п²п·п▓п п░ п╕п▓п∙п╒п·п▓


		.BYTE	'T,'D		;п°п≤п⌠п░п²п≤п╞ п пёп═п║п·п═п░
		CALL	GINT		;R1 - п÷п∙п═п▓п╚п≥ п╕п▓п∙п╒
		MOV	R2,R1		;R2 - п▓п╒п·п═п·п≥ п╕п▓п∙п╒
		CALL	GINT
		MOV	CRTGRP,R1
	RET0:	MOV	RETSCR(1),R1
		CALL	ESCLN
		RETURN
	RSCR::	MOV	CRTGRP,R1
		BNE	RET0
		RETURN
	CSCR::	TST	CRTGRP
		BEQ	1$
		CALL	CRET
		MOV	#17,R1
		ADD	RUSLAT,R1
	2$:	TSTB	@#GRPCSR
		BPL	2$
		MOVB	R1,@#GRPDBR
	1$:	RETURN
	;
	GINT::	MOV	R1,-(SP)	;п▓п╚п▓п·п■ п╕п∙п⌡п·п⌠п·
		BPL	1$
		NEG	R1
	1$:	MOV	R1,R0
		ASR	R0
		ASR	R0
		SWAB	R0
		BIS	#100,R0
		CALL	GOUT
		ASR	R0
		ASR	R0
		SWAB	R0
		BIC	#177700,R0
		BIS	#100,R0
		CALL	GOUT
		MOV	R1,R0
		BIC	#177760,R0
		MOV	(SP)+,R1
		BMI	2$
		BIS	#20,R0		; +
	2$:	BIS	#40,R0
	;
	GOUT::
		TSTB	@#GRPCSR	;п▓п╚п▓п·п■ п▒п░п≥п╒п░ R0
		BPL	GOUT		;п÷п· п⌠п═п░п╓п≤п╖п∙п║п п·п°пё п п░п²п░п⌡пё
		MOVB	R0,@#GRPDBR
		RETURN
	;
	GINP:
		TSTB	@#GICSR		;п▓п▓п·п■ п▒п░п≥п╒п░ п▓ R0
		BPL	GINP		;п║ п⌠п═п░п╓п≤п╖п∙п║п п·п⌠п· п п░п²п░п⌡п░
		MOVB	@#GIDBR,R0
		RETURN
	;
	GLNTST:	CALL	TSTXY		;п╖п∙п═п╖п∙п²п≤п∙ п÷п═п╞п°п·п≥ п■п·
	GLINE:	JSR	R5,GCOM		;X=R1, Y=R2


		.BYTE	'U,'G
		BR	GXYW
	;
	GPNTST:	CALL	TSTXY		;п▓п╚п▓п·п■ п╒п·п╖п п≤
	GPOINT:	JSR	R5,GCOM		;X=R1, Y=R2
		.BYTE	'U,'H
		BR	GXYW
	;
	GXYWT:	CALL	TSTXY
	GXYW:	ASL	R2		;п▓п╚п▓п·п■ п÷п░п═п╚ <XY> - R1,R2
		MOV	R2,R0		;HI Y
		SWAB	R0
		BIC	#177700,R0
		BIS	#40,R0
		CALL	GOUT
		MOV	R1,R0		;EXTRA
		ASL	R2
		BIC	#14,R0
		BIS	R2,R0
		BIC	#177760,R0
		BIS	#140,R0
		CALL	GOUT
		ASR	R2		;LO Y
		ASR	R2
		MOV	R2,R0
		ASR	R0
		ASR	R0
		BIC	#177740,R0
		BIS	#140,R0
		CALL	GOUT
		MOV	R1,R0		;HI X
		ASL	R0
		SWAB	R0
		BIC	#177740,R0
		BIS	#40,R0
		CALL	GOUT
		MOV	R1,R0		;LO X
		ASR	R0
		ASR	R0
		BIC	#177740,R0
		BIS	#100,R0
		CALL	GOUT
	;!	MOV	#100,@#ARSK
		RETURN
	;
	GXYST:	CALL	TSTXY		;пёп║п╒п░п²п·п▓п п░ п÷п·п⌡п·п√п∙п²п≤п╞
	GXYS::	JSR	R5,GCOM		;п⌠п═п░п╓п≤п╖п∙п║п п·п⌠п· п пёп═п║п·п═п░
		.BYTE	'U,'F		;X=R1, Y=R2
		CALL	GXYW
		RETURN
	;
	GERROR:	TRAP	5
	;
	GXYR:
		TST	CRTGRP
		BEQ	GERROR
	GXYRD:


		CALL	KBOFF
	;	MOV	#-2,R1		;п╖п╒п∙п²п≤п∙ п÷п·п⌡п·п√п∙п²п≤п╞
		JSR	R5,GCOM		;п⌠п═п░п╓п≤п╖п∙п║п п·п⌠п· п пёп═п║п·п═п░
		.BYTE	'U,'I		;X=R1, Y=R2
	;	CALL	GINT
		CLR	R1
		CLR	R2
		CALL	GINP		;HI Y
		BIC	#177740,R0
		MOV	R0,R2
		SWAB	R2
		ASR	R2
		CALL	GINP		;EXTRA
		MOV	R0,R1
		BIC	#177774,R1
		BIC	#177763,R0
		ASR	R0
		ASR	R0
		BIS	R0,R2
		CALL	GINP		;LO Y
		BIC	#177740,R0
		ASL	R0
		ASL	R0
		BIS	R0,R2
		CALL	GINP		;HI X
		BIC	#177740,R0
		SWAB	R0
		ASR	R0
		BIS	R0,R1
		CALL	GINP		;LO X
		BIC	#177740,R0
		ASL	R0
		ASL	R0
		BIS	R0,R1
		CALL	GINP
		CALL	KBON
	;!	MOV	#100,@#ARSK
		RETURN
